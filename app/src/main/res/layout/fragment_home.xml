<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/dark_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 头部 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OpenCore控制中心"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvVersionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OpenCore v1.0 Native Engine | 运行中"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvFeaturesCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="53项核心特性: 已启用 53/53"
            android:textSize="12sp"
            android:textColor="@color/primary_blue"
            android:layout_marginTop="2dp" />

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_color"
            android:layout_marginVertical="12dp" />

        <!-- 实时工作状态 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="实时工作状态"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_card">

            <TextView
                android:id="@+id/tvEngineLoad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="引擎负载: 12%"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvServiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="底层服务: 运行中"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvKprobeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="内核注入: 活跃"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvFeaturesList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="启用功能: 设备伪装, SELinux, SU权限..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Boot修补功能 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Boot修补功能"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_card">

            <TextView
                android:id="@+id/tvBootStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Boot镜像状态: 未修补"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvPatchProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="修补进度: 0%"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvFirmwareInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="固件适配: AOSP 13"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvPatchHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="修补历史: 无"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnPatchBoot"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="修补 Boot 镜像"
                android:layout_marginTop="12dp"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- 运行模式 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="运行模式"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_card"
            android:weightSum="3">

            <TextView
                android:id="@+id/modeMount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="挂载模式"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_mode_inactive" />

            <TextView
                android:id="@+id/modeKernel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="内核模式"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_mode_inactive" />

            <TextView
                android:id="@+id/modeMagisk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Magisk模块"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_mode_active" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
